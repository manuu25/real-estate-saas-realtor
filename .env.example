# Plantilla de variables del PORTAL REALTOR. Copia a .env y rellena (el .env NO se sube).
# En Streamlit Cloud estas van en Settings -> Secrets (formato TOML: CLAVE = "valor").

# Almacenamiento S3-compatible (Backblaze B2) — mismo bucket que el portal inquilino
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
S3_ENDPOINT_URL=
AWS_DEFAULT_REGION=

# MongoDB (login del realtor en coleccion 'users' + datos de inquilinos)
MONGO_AUTH=
MONGO_URI=

# LLM para el analisis IA — por defecto Groq (GRATIS, sin tarjeta, compatible con la API de OpenAI).
# Consigue una clave gratis en https://console.groq.com/keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Opcionales (la app tolera que falten):
STRIPE_API_KEY=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

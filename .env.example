# Plantilla de variables del PORTAL REALTOR. Copia a .env y rellena (el .env NO se sube).
# En Streamlit Cloud estas van en Settings -> Secrets (formato TOML: CLAVE = "valor").

# Almacenamiento S3-compatible (Backblaze B2) — mismo bucket que el portal inquilino
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
S3_ENDPOINT_URL=
AWS_DEFAULT_REGION=

# MongoDB (login del realtor en coleccion 'users' + datos de inquilinos)
MONGO_AUTH=
MONGO_URI=

# OpenAI (analisis IA). Opcional: sin ella la app arranca pero el analisis avisara.
OPENAI_API_KEY=

# Opcionales (la app tolera que falten):
STRIPE_API_KEY=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
